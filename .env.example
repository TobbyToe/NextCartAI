# AWS credentials — use OIDC in CI; only use keys for local dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-2

# RDS connection — get host from: terraform output rds_endpoint (strip the :5432)
RDS_HOST=instacart-dev.xxxxxxxxxx.ap-southeast-2.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=instacart
RDS_USER=instacart_admin
RDS_PASSWORD=
